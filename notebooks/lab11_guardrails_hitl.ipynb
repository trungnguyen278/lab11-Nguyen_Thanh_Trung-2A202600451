        "]\n",
        "\n",
        "print(\"Testing detect_injection():\")\n",
        "for text, expected in test_cases:\n",
        "    result = detect_injection(text)\n",
        "    status = \"PASS\" if result == expected else \"FAIL\"\n",
        "    print(f\"  [{status}] '{text[:55]}...' -> detected={result} (expected={expected})\")"
